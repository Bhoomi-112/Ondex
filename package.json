{
  "name": "ondex",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "build:contracts": "cargo build --target wasm32v1-none --release --manifest-path ./contracts/Cargo.toml",
    "deploy": "tsx scripts/deploy.ts",
    "deploy:token": "tsx scripts/deploy-platform-token.ts",
    "fund": "tsx scripts/fund-testnet-account.ts",
    "bindings:generate": "tsx packages/sdk/src/generate-bindings.ts",
    "test:contracts": "cargo test --manifest-path ./contracts/Cargo.toml"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "turbo": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.0.0"
}
