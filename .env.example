# Deployer (scripts only — never import into apps)
DEPLOYER_SECRET=

# Network (required for apps — no hardcoded fallbacks in business logic)
SOROBAN_RPC_URL=
HORIZON_URL=
SOROBAN_NETWORK_PASSPHRASE=
EXPLORER_BASE_URL=
NETWORK_NAME=

# Contract IDs — prefer reading contracts.json; optional overrides
CONTRACTS_JSON_PATH=./contracts.json
ESCROW_CONTRACT_ID=
JURY_REGISTRY_CONTRACT_ID=
IDENTITY_REGISTRY_CONTRACT_ID=
PLATFORM_TOKEN_CONTRACT_ID=
XLM_TOKEN_CONTRACT_ID=

# Admin (wallet public key that may call admin contract methods)
ADMIN_ADDRESS=

# Protocol init args (passed at deploy/initialize — not hardcoded in contracts)
# Use stroops / smallest units (e.g. 10 XLM = 100000000 if 7 decimals)
INIT_MIN_XLM_STAKE=
INIT_MIN_PLATFORM_STAKE=
INIT_JURY_SIZE=
INIT_QUORUM=
INIT_SLASH_PCT=
INIT_MIN_VOTE_CAPITAL_BPS=
INIT_TREASURY_ADDRESS=

# API
PORT=
# For local dev: file:./prisma/dev.db (SQLite)
# For production (Render): postgresql://user:pass@host:5432/ondex (Postgres)
DATABASE_URL=
# Deprecated: HS256 SESSION_SECRET — use RS256 keys below
SESSION_SECRET=
# Secrets backend: env | file (production: inject from AWS Secrets Manager / Vault)
SECRETS_BACKEND=env
# RS256 JWT signing keys (PEM). Use multiline PEM or file:/absolute/path.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
# Previous key pair during rotation (optional)
JWT_PRIVATE_KEY_PREVIOUS=
JWT_PUBLIC_KEY_PREVIOUS=
# MFA secret encryption key (rotate periodically)
MFA_ENCRYPTION_KEY=
# CAPTCHA (Turnstile/hCaptcha) — required after repeated auth failures
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=
# Alerts on role escalation / anomalies
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=
ALERT_EMAIL_API_URL=
NODE_ENV=
CORS_ORIGINS=
LOG_LEVEL=
AUTH_RATE_LIMIT_MAX=
RATE_LIMIT_MAX=
RATE_LIMIT_WINDOW_MS=

# Web (apps/web/.env.local)
# Leave empty in local dev so browser uses Next rewrite (/api → :3001) and cookies stay same-origin
# JWT_PUBLIC_KEY must match API public key (RS256 middleware verification)
JWT_PUBLIC_KEY=
JWT_PUBLIC_KEY_PREVIOUS=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOROBAN_RPC_URL=
NEXT_PUBLIC_HORIZON_URL=
NEXT_PUBLIC_NETWORK_PASSPHRASE=
NEXT_PUBLIC_EXPLORER_BASE_URL=
NEXT_PUBLIC_NETWORK_NAME=
NEXT_PUBLIC_ESCROW_CONTRACT_ID=
NEXT_PUBLIC_JURY_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_IDENTITY_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_PLATFORM_TOKEN_CONTRACT_ID=
NEXT_PUBLIC_XLM_TOKEN_CONTRACT_ID=
NEXT_PUBLIC_FRIENDBOT_URL=
NEXT_PUBLIC_CONTRACTS_JSON_URL=
NEXT_PUBLIC_DEFAULT_DISPUTE_WINDOW_SECS=

# Platform SAC deploy script
PLATFORM_ASSET_CODE=
STELLAR_NETWORK=

# AI Agent (automated juror) — Stellar keypair for the AI evaluation bot
AI_AGENT_SECRET_KEY=
AI_AGENT_PUBLIC_KEY=

# Document upload directory
UPLOAD_DIR=./uploads
