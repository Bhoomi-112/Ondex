{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "SOROBAN_RPC_URL",
        "SOROBAN_NETWORK_PASSPHRASE",
        "HORIZON_URL",
        "NEXT_PUBLIC_JURY_REGISTRY_CONTRACT"
      ]
    },
    "lint": {},
    "test": {}
  }
}
