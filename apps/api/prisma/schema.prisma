generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ContractEvent {
  id            String   @id @default(uuid())
  contractId    String   @map("contract_id")
  contractType  String   @map("contract_type") // escrow | jury | identity
  eventName     String   @map("event_name")
  ledgerSeq     Int      @map("ledger_seq")
  ledgerCloseAt DateTime @map("ledger_close_at")
  txHash        String   @map("tx_hash")
  topicXdr      String   @map("topic_xdr")
  dataXdr       String   @map("data_xdr")
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([txHash, eventName])
  @@index([contractType, processed])
  @@index([ledgerSeq])
  @@map("contract_events")
}

model Campaign {
  id              Int      @id @default(autoincrement())
  campaignId      Int      @unique @map("campaign_id")
  startupAddress  String   @map("startup_address")
  investorAddress String   @map("investor_address")
  amount          BigInt
  asset           String
  state           String   @default("Active") // Active | JuryApproved | DisputeOpen | Released | Refunded
  createdAt       DateTime @default(now()) @map("created_at")
  approvedAt      DateTime? @map("approved_at")
  disputeDeadline DateTime? @map("dispute_deadline")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([state])
  @@index([startupAddress])
  @@index([investorAddress])
  @@map("campaigns")
}

model JuryCase {
  id            Int      @id @default(autoincrement())
  caseId        Int      @unique @map("case_id")
  status        String   @default("Voting") // Voting | Resolved | Disputed | Slashed
  forVotes      Int      @default(0) @map("for_votes")
  againstVotes  Int      @default(0) @map("against_votes")
  totalVotes    Int      @default(0) @map("total_votes")
  resolvedAt    DateTime? @map("resolved_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  jurors        CaseJuror[]
  votes         CaseVote[]

  @@index([status])
  @@map("jury_cases")
}

model CaseJuror {
  id        Int      @id @default(autoincrement())
  caseId    Int      @map("case_id")
  jurorAddr String   @map("juror_address")
  assignedAt DateTime @default(now()) @map("assigned_at")

  case      JuryCase @relation(fields: [caseId], references: [caseId])

  @@unique([caseId, jurorAddr])
  @@index([jurorAddr])
  @@map("case_jurors")
}

model CaseVote {
  id        Int      @id @default(autoincrement())
  caseId    Int      @map("case_id")
  jurorAddr String   @map("juror_address")
  vote      String   // For | Against
  timestamp DateTime @default(now())

  case      JuryCase @relation(fields: [caseId], references: [caseId])

  @@unique([caseId, jurorAddr])
  @@map("case_votes")
}

model Juror {
  id             Int      @id @default(autoincrement())
  address        String   @unique
  xlmStake       BigInt   @map("xlm_stake")
  platformStake  BigInt   @map("platform_stake")
  registeredAt   DateTime @default(now()) @map("registered_at")
  isActive       Boolean  @default(true) @map("is_active")

  @@map("jurors")
}

model Identity {
  id             Int      @id @default(autoincrement())
  identityId     String   @unique @map("identity_id")
  commitmentHash String?  @map("commitment_hash")
  isCommitted    Boolean  @default(false) @map("is_committed")
  isRevealed     Boolean  @default(false) @map("is_revealed")
  linkedCaseId   Int?     @map("linked_case_id")
  backendRef     String?  @map("backend_ref")
  revealedAt     DateTime? @map("revealed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([isCommitted])
  @@index([isRevealed])
  @@map("identities")
}

/// Opaque session rows kept for migration compatibility; auth uses JWT + refresh_tokens.
model Session {
  id        String   @id @default(uuid())
  wallet    String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([wallet])
  @@index([expiresAt])
  @@map("sessions")
}

model User {
  id               String   @id @default(uuid())
  wallet           String?  @unique
  email            String?  @unique
  /// founder | investor | jury — set once; only admin may change
  role             String?
  /// role_selected | profile_complete | active
  onboardingStatus String   @default("role_selected") @map("onboarding_status")
  displayName      String?  @map("display_name")
  bio              String?
  /// TOTP secret (encrypted at rest via app-layer) for admin MFA
  mfaSecret        String?  @map("mfa_secret")
  mfaEnabled       Boolean  @default(false) @map("mfa_enabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  refreshTokens        RefreshToken[]
  juryApplications     JuryApplication[]
  applications         Application[]
  investorApplications InvestorApplication[]
  authEvents           AuthEvent[]
  auditLogsAsActor     AuditLog[] @relation("AuditActor")
  auditLogsAsTarget    AuditLog[] @relation("AuditTarget")

  @@index([role])
  @@index([onboardingStatus])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  /// Session family — reuse of any rotated member revokes the whole family
  familyId   String    @map("family_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Single-use wallet auth challenges (SEP-10 style nonces)
model AuthChallenge {
  id            String   @id @default(uuid())
  wallet        String
  nonce         String   @unique
  challengeHash String   @unique @map("challenge_hash")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([wallet])
  @@index([expiresAt])
  @@map("auth_challenges")
}

/// Immutable audit trail for role changes and privileged actions
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  actorId   String?  @map("actor_id")
  targetId  String?  @map("target_id")
  oldRole   String?  @map("old_role")
  newRole   String?  @map("new_role")
  ip        String?
  metadata  String?  // JSON string for sqlite portability
  createdAt DateTime @default(now()) @map("created_at")

  actor  User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  target User? @relation("AuditTarget", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Auth event stream for monitoring / anomaly detection
model AuthEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  eventType   String   @map("event_type")
  success     Boolean
  ip          String?
  fingerprint String?
  geoHint     String?  @map("geo_hint")
  detail      String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([ip])
  @@index([createdAt])
  @@map("auth_events")
}

/// Per-IP / per-account auth failure counters for backoff + CAPTCHA
model AuthFailureBucket {
  id           String   @id @default(uuid())
  bucketKey    String   @unique @map("bucket_key")
  failCount    Int      @default(0) @map("fail_count")
  captchaRequired Boolean @default(false) @map("captcha_required")
  lockedUntil  DateTime? @map("locked_until")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("auth_failure_buckets")
}

/// pending_jury_application — not an active role until admin promotes user to jury
model JuryApplication {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  wallet       String
  /// pending | approved | rejected
  status       String    @default("pending")
  statement    String
  experience   String?
  reviewedBy   String?   @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")
  rejectReason String?   @map("reject_reason")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
  @@index([wallet])
  @@map("pending_jury_applications")
}



/// pending_investor_application — not an active role until admin approves
model InvestorApplication {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  wallet             String
  /// pending | approved | rejected
  status             String    @default("pending")
  fullName           String    @map("full_name")
  entityType         String?   @map("entity_type")
  accreditation      String?
  aum                String?
  sourceOfFunds      String?   @map("source_of_funds")
  portfolioDesc      String?   @map("portfolio_desc")
  experienceLevel    String?   @map("experience_level")
  companiesInvested  String?   @map("companies_invested")
  sectorFocus        String?   @map("sector_focus")
  investmentRange    String?   @map("investment_range")
  previousPortfolio  String?   @map("previous_portfolio")
  referralSource     String?   @map("referral_source")
  reviewedBy         String?   @map("reviewed_by")
  reviewedAt         DateTime? @map("reviewed_at")
  rejectReason       String?   @map("reject_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
  @@index([wallet])
  @@map("pending_investor_applications")
}

model Notification {
  id        String   @id @default(uuid())
  wallet    String
  type      String   // jury_assigned | vote_received | escrow_released | round_closed | dispute_opened
  title     String
  body      String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([wallet, read])
  @@map("notifications")
}

model IndexerCursor {
  id              String   @id @default("singleton")
  lastLedgerSeq   Int      @default(0) @map("last_ledger_seq")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("indexer_cursor")
}

model Application {
  id            Int      @id @default(autoincrement())
  userId        String?  @map("user_id")
  onChainId     Int?     @unique @map("on_chain_id")
  wallet        String   @map("wallet")
  name          String
  pitch         String
  askAmount     BigInt   @default(0) @map("ask_amount")
  experience    String?
  website       String?
  socials       String?  // JSON: { twitter?, github?, linkedin? }
  status        String   @default("pending")
  reviewedBy    String?  @map("reviewed_by")
  reviewedAt    DateTime? @map("reviewed_at")
  rejectReason  String?  @map("reject_reason")
  maskName      Boolean  @default(true) @map("mask_name")
  maskAddress   Boolean  @default(true) @map("mask_address")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones    ApplicationMilestone[]
  votes         ApplicationVote[]

  @@index([userId])
  @@index([wallet])
  @@index([status])
  @@map("applications")
}

model ApplicationMilestone {
  id            Int         @id @default(autoincrement())
  applicationId Int         @map("application_id")
  idx           Int
  description   String
  amount        BigInt
  released      Boolean     @default(false)

  application   Application @relation(fields: [applicationId], references: [id])

  @@unique([applicationId, idx])
  @@map("application_milestones")
}

model ApplicationVote {
  id            Int         @id @default(autoincrement())
  applicationId Int         @map("application_id")
  voter         String
  approve       Boolean
  commentHash   String      @default("") @map("comment_hash")
  timestamp     DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id])

  @@unique([applicationId, voter])
  @@index([voter])
  @@map("application_votes")
}
