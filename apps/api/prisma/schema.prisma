generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContractEvent {
  id            String   @id @default(uuid())
  contractId    String   @map("contract_id")
  contractType  String   @map("contract_type") // escrow | identity
  eventName     String   @map("event_name")
  ledgerSeq     Int      @map("ledger_seq")
  ledgerCloseAt DateTime @map("ledger_close_at")
  txHash        String   @map("tx_hash")
  topicXdr      String   @map("topic_xdr")
  dataXdr       String   @map("data_xdr")
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([txHash, eventName])
  @@index([contractType, processed])
  @@index([ledgerSeq])
  @@map("contract_events")
}

model Campaign {
  id              Int      @id @default(autoincrement())
  campaignId      Int      @unique @map("campaign_id")
  startupAddress  String   @map("startup_address")
  investorAddress String   @map("investor_address")
  amount          BigInt
  asset           String
  state           String   @default("Active") // Active | MilestoneRequested | Released | Refunded
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([state])
  @@index([startupAddress])
  @@index([investorAddress])
  @@map("campaigns")
}

model StartupProfile {
  id             Int      @id @default(autoincrement())
  wallet         String   @unique
  name           String
  description    String
  industryTags   String   @map("industry_tags")
  fundingAsk     BigInt   @map("funding_ask")
  equityOffered  Int      @map("equity_offered")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("startup_profiles")
}

model InvestorProfile {
  id                  Int      @id @default(autoincrement())
  wallet              String   @unique
  preferredIndustries String   @map("preferred_industries")
  minTicket           BigInt   @map("min_ticket")
  maxTicket           BigInt   @map("max_ticket")
  preferredStage      String   @map("preferred_stage")
  kycHash             String?  @map("kyc_hash")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("investor_profiles")
}

model MatchScore {
  id           Int      @id @default(autoincrement())
  startupWallet String  @map("startup_wallet")
  investorWallet String @map("investor_wallet")
  score        Float
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([startupWallet, investorWallet])
  @@index([startupWallet, score])
  @@index([investorWallet, score])
  @@map("match_scores")
}

model Meeting {
  id             String   @id @default(uuid())
  startupWallet  String   @map("startup_wallet")
  investorWallet String   @map("investor_wallet")
  status         String   @default("pending") // pending | accepted | rejected | completed
  roomUrl        String?  @map("room_url")
  scheduledAt    DateTime? @map("scheduled_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([startupWallet])
  @@index([investorWallet])
  @@index([status])
  @@map("meetings")
}

model CreditPurchase {
  id            String   @id @default(uuid())
  startupWallet String   @map("startup_wallet")
  amount        BigInt
  credits       Int
  txHash        String?  @map("tx_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([startupWallet])
  @@map("credit_purchases")
}

model CreditBalance {
  id            String   @id @default(uuid())
  startupWallet String   @unique @map("startup_wallet")
  balance       Int      @default(0)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("credit_balances")
}

/// Opaque session rows kept for migration compatibility; auth uses JWT + refresh_tokens.
model Session {
  id        String   @id @default(uuid())
  wallet    String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([wallet])
  @@index([expiresAt])
  @@map("sessions")
}

model User {
  id               String   @id @default(uuid())
  wallet           String?  @unique
  email            String?  @unique
  /// founder | investor — set once; only admin may change
  role             String?
  /// role_selected | profile_complete | active
  onboardingStatus String   @default("role_selected") @map("onboarding_status")
  displayName      String?  @map("display_name")
  bio              String?
  /// TOTP secret (encrypted at rest via app-layer) for admin MFA
  mfaSecret        String?  @map("mfa_secret")
  mfaEnabled       Boolean  @default(false) @map("mfa_enabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  refreshTokens        RefreshToken[]
  applications         Application[]
  investorApplications InvestorApplication[]
  authEvents           AuthEvent[]
  auditLogsAsActor     AuditLog[] @relation("AuditActor")
  auditLogsAsTarget    AuditLog[] @relation("AuditTarget")

  @@index([role])
  @@index([onboardingStatus])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  /// Session family — reuse of any rotated member revokes the whole family
  familyId   String    @map("family_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Single-use wallet auth challenges (SEP-10 style nonces)
model AuthChallenge {
  id            String   @id @default(uuid())
  wallet        String
  nonce         String   @unique
  challengeHash String   @unique @map("challenge_hash")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([wallet])
  @@index([expiresAt])
  @@map("auth_challenges")
}

/// Immutable audit trail for role changes and privileged actions
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  actorId   String?  @map("actor_id")
  targetId  String?  @map("target_id")
  oldRole   String?  @map("old_role")
  newRole   String?  @map("new_role")
  ip        String?
  metadata  String?  // JSON string for sqlite portability
  createdAt DateTime @default(now()) @map("created_at")

  actor  User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  target User? @relation("AuditTarget", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Auth event stream for monitoring / anomaly detection
model AuthEvent {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  eventType   String   @map("event_type")
  success     Boolean
  ip          String?
  fingerprint String?
  geoHint     String?  @map("geo_hint")
  detail      String?
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([ip])
  @@index([createdAt])
  @@map("auth_events")
}

/// Per-IP / per-account auth failure counters for backoff + CAPTCHA
model AuthFailureBucket {
  id           String   @id @default(uuid())
  bucketKey    String   @unique @map("bucket_key")
  failCount    Int      @default(0) @map("fail_count")
  captchaRequired Boolean @default(false) @map("captcha_required")
  lockedUntil  DateTime? @map("locked_until")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("auth_failure_buckets")
}

/// pending_investor_application — not an active role until admin approves
model InvestorApplication {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  wallet             String
  /// pending | approved | rejected
  status             String    @default("pending")
  fullName           String    @map("full_name")
  entityType         String?   @map("entity_type")
  accreditation      String?
  aum                String?
  sourceOfFunds      String?   @map("source_of_funds")
  portfolioDesc      String?   @map("portfolio_desc")
  experienceLevel    String?   @map("experience_level")
  companiesInvested  String?   @map("companies_invested")
  sectorFocus        String?   @map("sector_focus")
  investmentRange    String?   @map("investment_range")
  previousPortfolio  String?   @map("previous_portfolio")
  referralSource     String?   @map("referral_source")
  reviewedBy         String?   @map("reviewed_by")
  reviewedAt         DateTime? @map("reviewed_at")
  rejectReason       String?   @map("reject_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
  @@index([wallet])
  @@map("pending_investor_applications")
}

model Notification {
  id        String   @id @default(uuid())
  wallet    String
  type      String   // meeting_request | meeting_accepted | escrow_released | match_found
  title     String
  body      String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([wallet, read])
  @@map("notifications")
}

model IndexerCursor {
  id              String   @id @default("singleton")
  lastLedgerSeq   Int      @default(0) @map("last_ledger_seq")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("indexer_cursor")
}

model Application {
  id            Int      @id @default(autoincrement())
  userId        String?  @map("user_id")
  onChainId     Int?     @unique @map("on_chain_id")
  wallet        String   @map("wallet")
  name          String
  pitch         String
  askAmount     BigInt   @default(0) @map("ask_amount")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones    ApplicationMilestone[]
  votes         ApplicationVote[]
  documents     StartupDocument[]
  aiEvaluations AiEvaluation[]

  @@index([userId])
  @@index([wallet])
  @@index([status])
  @@map("applications")
}

model ApplicationMilestone {
  id            Int         @id @default(autoincrement())
  applicationId Int         @map("application_id")
  idx           Int
  description   String
  amount        BigInt
  released      Boolean     @default(false)

  application   Application @relation(fields: [applicationId], references: [id])

  @@unique([applicationId, idx])
  @@map("application_milestones")
}

model ApplicationVote {
  id            Int         @id @default(autoincrement())
  applicationId Int         @map("application_id")
  voter         String
  approve       Boolean
  commentHash   String      @default("") @map("comment_hash")
  timestamp     DateTime    @default(now())

  application   Application @relation(fields: [applicationId], references: [id])

  @@unique([applicationId, voter])
  @@index([voter])
  @@map("application_votes")
}

model StartupDocument {
  id            Int         @id @default(autoincrement())
  applicationId Int         @map("application_id")
  fileName      String      @map("file_name")
  fileType      String      @map("file_type")
  filePath      String      @map("file_path")
  fileSize      Int         @map("file_size")
  category      String      @default("other")
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")

  application   Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@map("startup_documents")
}

model AiEvaluation {
  id                Int         @id @default(autoincrement())
  caseId            Int         @unique @map("case_id")
  applicationId     Int         @map("application_id")
  aiAgentAddress    String      @map("ai_agent_address")
  status            String      @default("pending")
  score             Int?
  verdict           String?
  confidenceScore   Float?      @map("confidence_score")
  webPresenceScore  Int?        @map("web_presence_score")
  newsSentiment     String?     @map("news_sentiment")
  companyVerified   Boolean?    @map("company_verified")
  documentScore     Int?        @map("document_score")
  evidenceReport    String?     @map("evidence_report")
  errorMessage      String?     @map("error_message")
  txHash            String?     @map("tx_hash")
  startedAt         DateTime?   @map("started_at")
  completedAt       DateTime?   @map("completed_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  application       Application @relation(fields: [applicationId], references: [id])

  @@index([status])
  @@index([applicationId])
  @@map("ai_evaluations")
}
